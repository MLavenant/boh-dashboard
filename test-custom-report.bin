<script type='text/javascript'>
    var decodeHTML = function (html) {
        var text = document.createElement('textarea');
        text.innerHTML = html;
        return text.value;
    };

    var initESW = function (gslbBaseURL) {
        var chatConfig = {
            // salesforce config
            eswJSUrl: 'https://toast.my.salesforce.com/embeddedservice/5.0/esw.min.js',
            svcInitEndpoint: 'https://toast.my.salesforce.com',
            svcChatEndpoint: 'https://d.la3-c2-ph2.salesforceliveagent.com/chat',
            svcContentEndpoint: 'https://c.la3-c2-ph2.salesforceliveagent.com/content',
            deploymentId: '5723c000000k9iJ',
            buttonId: '573C00000008RMb',
            eswLiveAgentDevName: 'EmbeddedServiceLiveAgent_Parent04I3c0000000CK9EAM_174b30518e1',
            svcSiteEndpoint: 'https://central.toasttab.com/',
            snapinName: 'Toast_Web_Chat_V2',
            orgId: '00DC00000017Bak',
            displayHelpButton: false

        };

        embedded_svc.settings.displayHelpButton = chatConfig.displayHelpButton;
        embedded_svc.settings.language = ''; //For example, enter 'en' or 'en-US'

        embedded_svc.settings.enabledFeatures = ['LiveAgent'];
        embedded_svc.settings.entryFeature = 'LiveAgent';
        embedded_svc.settings.prepopulatedPrechatFields = {
            FirstName: decodeHTML('Matthias'),
            LastName: decodeHTML('Lavenant'),
            Restaurant_Name__c: decodeHTML('AVA MediterrAegean')
        };

        embedded_svc.settings.extraPrechatFormDetails = [{"label":"I have a question about", "transcriptFields": ["I_have_a_question_about__c"]}];

        embedded_svc.init(
            chatConfig.svcInitEndpoint,
            chatConfig.svcSiteEndpoint,
            gslbBaseURL,
            chatConfig.orgId,
            chatConfig.snapinName,
            {
                baseLiveAgentContentURL: chatConfig.svcContentEndpoint,
                deploymentId: chatConfig.deploymentId,
                buttonId: chatConfig.buttonId,
                baseLiveAgentURL: chatConfig.svcChatEndpoint,
                eswLiveAgentDevName: chatConfig.eswLiveAgentDevName,
                isOfflineSupportEnabled: false
            }
        );
    };

    if (!window.embedded_svc) {
        var s = document.createElement('script');
        s.setAttribute('src', chatConfig.eswJSUrl);
        s.onload = function () {
            initESW(null);
        };
        document.body.appendChild(s);
    } else {
        initESW('https://service.force.com');
    }
</script>
            
    
