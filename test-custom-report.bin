<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
<head>
    <script>
    (function () {

        window.fides_overrides = {
            fides_consent_non_applicable_flag_mode: "include",
            fides_consent_flag_type: "boolean",
            ot_fides_mapping: encodeURIComponent(JSON.stringify({
                /*Strictly Necessary*/ "C0001": ["essential"],
                /*Performance*/ "C0002": ["analytics"],
                /*Functional*/ "C0003": ["functional"],
                /*Targeting*/ "C0004": ["marketing"]
            }))
        };

        var fidesHost = "https://toast.fides-cdn.ethyca.com/fides.js";
        var fidesPropertyId = "FDS-A6VAWQ";
        var fidesSrc = fidesHost + "?property_id=" + fidesPropertyId + "&";

        function insertFidesScript() {
            addEventListener("FidesInitializing", function () {
                window.Fides.gtm();
            });

            addEventListener("FidesInitialized", function () {
                addExperienceIdToBody();
            });

            function addExperienceIdToBody() {
                try {
                    var experience = window.Fides.experience || {};
                    var config = experience.experience_config || {};
                    var id = config.id;
                    if (id) {
                        window.document.body.classList.add(id);
                    }
                } catch {
                    console.warn("Couldn't apply Fides experience ID to body.");
                }
            }

            var fidesPrefix = "fides_";
            var searchParams = new URLSearchParams(location.search);
            var fidesSearchParams = new URLSearchParams();
            searchParams.forEach(function (value, key) {
                if (key.startsWith(fidesPrefix)) {
                    fidesSearchParams.set(
                        key.replace(fidesPrefix, ""),
                        key === fidesPrefix + "cache_bust" ? Date.now().toString() : value
                    );
                }
            });

            var src = fidesSrc + fidesSearchParams.toString();
            var script = document.createElement("script");
            script.async = false;
            script.defer = false;
            script.setAttribute("src", src);
            script.setAttribute("id", "fides-js");
            script.setAttribute("type", "text/javascript");
            document.head.appendChild(script);
        }

        insertFidesScript();
    })();
</script>

<script type="text/javascript">
    (function() {
        function conditionallyLoad() {
            var consentData = {
                hasPerformanceConsent: Fides?.consent?.analytics || false,
                hasTargetingConsent: Fides?.consent?.marketing || false,
                hasFunctionalConsent: Fides?.consent?.functional || false
            };
            
            console.debug('[Consent Debug] consent.html: conditionallyLoad called', { consentData: consentData });
            
            handlePlatformVendorConsent(consentData);
        }
        
        function handlePlatformVendorConsent(consent) {
            // Google Analytics/GTM
            if (window.gtag) {
                console.debug('[Consent Debug] consent.html: Updating gtag consent');
                gtag('consent', 'update', {
                    'analytics_storage': consent.hasPerformanceConsent ? 'granted' : 'denied',
                    'ad_storage': consent.hasTargetingConsent ? 'granted' : 'denied',
                    'ad_user_data': consent.hasTargetingConsent ? 'granted' : 'denied',
                    'ad_personalization': consent.hasTargetingConsent ? 'granted' : 'denied'
                });
            }
            
            // Amplitude opt-out
            if (window.amplitude) {
                console.debug('[Consent Debug] consent.html: Updating Amplitude opt-out', { optOut: !consent.hasPerformanceConsent });
                amplitude.setOptOut(!consent.hasPerformanceConsent);
            }
            
            // DataDog RUM
            if (typeof window.DD_RUM !== 'undefined' && window.DD_RUM.setTrackingConsent) {
                var ddConsent = consent.hasPerformanceConsent ? 'granted' : 'not-granted';
                console.debug('[Consent Debug] consent.html: Updating DD_RUM tracking consent', { ddConsent: ddConsent });
                window.DD_RUM.setTrackingConsent(ddConsent);
            }
            
            // Heap
            if (typeof window.heap !== 'undefined') {
                console.debug('[Consent Debug] consent.html: Updating Heap consent flag', { consentGranted: consent.hasPerformanceConsent });
                window.heap._consentGranted = consent.hasPerformanceConsent;
            }
            
            // FullStory
            if (typeof window.FS !== 'undefined') {
                console.debug('[Consent Debug] consent.html: Updating FullStory consent', { hasConsent: consent.hasTargetingConsent });
                if (window.FS.consent) {
                    window.FS.consent(consent.hasTargetingConsent);
                } else {
                    if (consent.hasTargetingConsent) {
                        if (window.FS.restart) window.FS.restart();
                    } else {
                        if (window.FS.shutdown) window.FS.shutdown();
                    }
                }
            }

            // Tealium
            if (typeof window.utag !== 'undefined' && window.utag.gdpr) {
                console.debug('[Consent Debug] consent.html: Updating Tealium consent');
                window.utag.gdpr.setConsentValue(consent.hasPerformanceConsent ? 1 : 0);
                window.utag.gdpr.setConsentCategories([
                    consent.hasPerformanceConsent ? 'analytics' : '',
                    consent.hasTargetingConsent ? 'advertising' : '',
                    consent.hasFunctionalConsent ? 'functional' : ''
                ].filter(Boolean));
            }
        }

        if (window.Fides?.initialized) {
            conditionallyLoad();
        } else {
            window.addEventListener('FidesInitialized', conditionallyLoad);
        }

        window.addEventListener('FidesUpdated', conditionallyLoad);
    })();
</script>
    <script type="text/javascript">
    (function() {
        var rumLoaded = false;

        function conditionallyLoad() {
            const DD_RUM_CONFIG ={
clientToken: 'pub060dac664356492dcb3856a3f719cc62',
applicationId: 'f560ab4c-a844-43fd-8577-c6feaefa967f',
site: 'datadoghq.com',
service:'toastweb',
env:'prod',
version: 'bob-release-468-3',
sessionSampleRate: 100,
sessionReplaySampleRate: 0,
allowedTracingOrigins: ['https://www.toasttab.com'],
trackInteractions: true,
traceSampleRate: 1,
traceContextInjection: 'sampled'
}

            console.debug('[Consent Debug] rum.html: conditionallyLoad called', { analyticsConsent: Fides?.consent?.analytics, rumLoaded: rumLoaded, ddRumDefined: typeof DD_RUM !== 'undefined' });

            if (Fides?.consent?.analytics) {
                if (!rumLoaded) {
                    console.debug('[Consent Debug] rum.html: Analytics consent granted, loading DataDog RUM script');
                    rumLoaded = true;
                    (function(h,o,u,n,d) {
                        h=h[d]=h[d]||{q:[],onReady:function(c){h.q.push(c)}}
                        d=o.createElement(u);d.async=1;d.src=n
                        n=o.getElementsByTagName(u)[0];n.parentNode.insertBefore(d,n)
                    })(window,document,'script','https://www.datadoghq-browser-agent.com/us1/v6/datadog-rum.js','DD_RUM')

                    DD_RUM.onReady(function() {
                        console.debug('[Consent Debug] rum.html: DD_RUM ready, initializing');
                        DD_RUM.init(DD_RUM_CONFIG);
                    });
                } else if (typeof DD_RUM !== 'undefined' && DD_RUM.setTrackingConsent) {
                    console.debug('[Consent Debug] rum.html: DD_RUM already loaded, setting tracking consent to granted');
                    DD_RUM.setTrackingConsent('granted');
                }
            } else {
                if (typeof DD_RUM !== 'undefined' && DD_RUM.setTrackingConsent) {
                    console.debug('[Consent Debug] rum.html: Analytics consent not granted, setting tracking consent to not-granted');
                    DD_RUM.setTrackingConsent('not-granted');
                } else {
                    console.debug('[Consent Debug] rum.html: Analytics consent not granted, DD_RUM not yet loaded');
                }
            }
        }

        if (window.Fides?.initialized) {
            conditionallyLoad();
        } else {
            window.addEventListener('FidesInitialized', conditionallyLoad);
        }

        window.addEventListener('FidesUpdated', conditionallyLoad);
    })();
</script>
