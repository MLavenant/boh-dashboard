<script src="https://cdn.toasttab.com/bob-release-468-3/javascripts/jquery.cookie.js"></script>
<script>

function getRestaurantId(){
    var toastSessionCookie = $.cookie('TOAST_SESSION');
    return toastSessionCookie.match(/[-&]rGuid=(.+?)[&"]/)[1];
}

function hideWarning() {
    $("#sessionWarning").addClass('hidden')
}

var existingRestaurantId = getRestaurantId();
window.onfocus = function(){
    if (document.cookie.indexOf(existingRestaurantId) < 0) {
        var elements = $("#sessionWarning");
        if (elements.length>0) {
            elements.removeClass('hidden')
        }
    }
};
</script>
