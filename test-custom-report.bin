            <!-- Global header skeletons -->
<style>

    /* Mobile skeleton */
    .global-header-top-skeleton {
        background:white;
        border-bottom:1px solid rgba(0,0,0,0.12);
        height:3rem;
        position:absolute;
        width:100%;
        top:0;
        z-index:10;
    }

    .left-rail-skeleton, .desktop-skeleton-logo {
        display: none;
    }

    /* Desktop skeleton */
    @media(min-width:768px) {
        .global-header-top-skeleton {
            background:white;
            border-bottom:1px solid rgba(0,0,0,0.12);
            height:4rem;
            position:fixed;
            width:100%;
            top:0;
        }

        .left-rail-skeleton {
            background: white;
            border-right: 1px solid rgba(0, 0, 0, 0.12);
            height: calc(100vh - 4rem);
            display: block;
            position: fixed;
            width: var(--global-left-margin);
            left: 0;
            bottom: 0;
        }

        .desktop-skeleton-logo {
            background: white;
            height: 4rem;
            top: 0;
            width: var(--global-logo-width, 4rem);
            left: 0;
            position: fixed;
            display: block;
        }
        .basic-skeleton .global-header-top-skeleton {
            border-bottom:none;
        }
    }

    .global-navigation-desktop {
        --global-header-margin: 4rem;
        padding-top: var(--global-header-margin);
    }

    .global-navigation-mobile {
        --global-header-margin: 3rem;
        padding-top: var(--global-header-margin);
    }

    .navigation-active {
        --global-left-margin: 13rem;
        --global-logo-width: 13rem;
        margin-left: var(--global-left-margin);
    }

    .navigation-inactive {
        --global-left-margin: 0rem;
        --global-logo-width: 4rem;
        margin-left: var(--global-left-margin);
    }

    @media(min-width: 1024px) {
        .navigation-inactive {
            --global-left-margin: 4rem;
            margin-left: var(--global-left-margin);
        }
    }

    @media print {
        .navigation-inactive {
            margin-top: 0 !important;
            padding-top: 0 !important;
            margin-left: 0 !important;
        }
    }
</style>
<div class="global-header-top-skeleton">
    <div class="desktop-skeleton-logo"></div>
    <div class="left-rail-skeleton"></div>
</div>
<script>


    // Determine if the left rail subnav should be open based on (1) local storage left rail state, (2) whether current page is home page
    var isHomepage = window.location.pathname === "/restaurants/admin/home"
    var storedState = window.localStorage.getItem('left-rail-state');
    var isOpen = Boolean(storedState === "true" || (storedState === null && isHomepage));

    // Apply the correct classes based on (1) window size, (2) local storage left rail state, (3) feature flags
    adjustHeaderMarginBasedOnWindowSize(window.innerWidth)
    adjustLeftRailBasedOnWindowSize(window.innerWidth, isOpen)

    function adjustHeaderMarginBasedOnWindowSize(size) {
        if (size < 768) {
            document.body.classList.remove('global-navigation-desktop');
            document.body.classList.add('global-navigation-mobile')
        } else {
            document.body.classList.remove('global-navigation-mobile')
            document.body.classList.add('global-navigation-desktop');
        }
    }

    function adjustLeftRailBasedOnWindowSize(size, isOpen) {

        if (size < 768) {
            document.body.classList.remove('navigation-inactive');
            document.body.classList.remove('navigation-active');
        } else if (isOpen) {
            document.body.classList.add('navigation-active');
            document.body.classList.remove('navigation-inactive');
        } else if (!isOpen && size < 1024) {
            document.body.classList.remove('navigation-inactive');
            document.body.classList.remove('navigation-active');
        } else if (!isOpen && size >= 1024) {
            document.body.classList.remove('navigation-active');
            document.body.classList.add('navigation-inactive');
        } else {
            document.body.classList.remove('navigation-inactive');
            document.body.classList.remove('navigation-active');
        }
    }


</script>

    
